// SECURITY FIX (Sprint 1, Finding #1):
// This used to call api.anthropic.com directly from the browser,
// which exposes the API key to anyone with DevTools open.
// It now calls our own /api/claude serverless route — the key
// never reaches the browser. Used by Rubric, Scheduler, and Feynman
// (features still on the shared generic route). A 20-second client-side
// timeout prevents the UI from spinning forever if the network stalls.
const callAI = async (prompt) => {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 20000);
  try {
    const res = await fetch('/api/claude', {
      method:'POST',
      headers:{ 'Content-Type':'application/json' },
      body: JSON.stringify({ prompt }),
      signal: controller.signal,
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(d.error || `Server error — HTTP ${res.status}`);
    if (d.error) throw new Error(d.error);
    return d.text ?? 'No response received.';
  } catch (e) {
    if (e.name === 'AbortError') throw new Error('Request timed out after 20s. Try again — the AI service may be busy.');
    throw e;
  } finally {
    clearTimeout(timer);
  }
};

// AI GRADER — now calls its OWN dedicated route (/api/grade) instead of
// building a giant free-text prompt in the browser. The server owns the
// JSON contract, validates input, and returns a real structured object
// instead of a wall of text the UI has to guess how to parse.
const gradeSubmission = async ({ subject, gradeLevel, standard, standardCode, assignmentPrompt, studentWork, maxScore }) => {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 25000);
  try {
    const res = await fetch('/api/grade', {
      method:'POST',
      headers:{ 'Content-Type':'application/json' },
      body: JSON.stringify({ subject, gradeLevel, standard, standardCode, assignmentPrompt, studentWork, maxScore }),
      signal: controller.signal,
    });
    const d = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(d.error || `Server error — HTTP ${res.status}`);
    if (d.error) throw new Error(d.error);
    return d; // { score, maxScore, percentage, letterGrade, rubricBreakdown, strengths, weaknesses, feedback, suggestedRevisions, flagForReview, flagReason }
  } catch (e) {
    if (e.name === 'AbortError') throw new Error('Grading timed out after 25s. Try again, or shorten the student submission.');
    throw e;
  } finally {
    clearTimeout(timer);
  }
};

// PERSISTENCE (Sprint 1, Finding #2 fix):
// Zero-cost localStorage bridge — survives page refresh, browser close,
// and tab crashes. This is not a real database (it's per-browser, not
// per-account), but it eliminates the #1 beta-killer bug: "I lost
// everything when I refreshed the page." Wrapped in try/catch because
// localStorage can throw in private-browsing mode on some browsers.
const STORAGE_KEY = 'gradefreed_v1';

const loadSaved = () => {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : null;
  } catch { return null; }
};

const saveState = (data) => {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch { /* private mode — silently skip */ }
};

const buildProfile = (a) => {
  const hrsMap = { 2:2, 5:5, 9:9, 14:14, 20:20 };
  const hrs = hrsMap[Number(a[6])] ?? 9;
  return {
    brainType:      a[1] ?? 'Neurotypical',
    chronotype:     a[2] ?? 'Bear',
    focusMins:      a[3] ?? '25',
    currentHours:   hrs,
    savedHours:     Math.round(hrs * 0.9),
    remainingHours: Math.max(1, Math.round(hrs * 0.1)),
    subject:        a[9] ?? 'General Teaching',
    goal:           a[8] ?? 'time',
    createdAt:      new Date().toLocaleDateString(),
  };
};

