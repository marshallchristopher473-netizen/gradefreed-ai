        <Card accent={C.amber}>
          <p style={{ color:C.amber, fontSize:12, marginBottom:8 }}>⚠️ Complete the Brain Diagnostic first for a schedule tailored to your chronotype and brain type.</p>
          <button onClick={() => setTab('diagnostic')} style={{ background:'none', border:'none', color:C.cyan, fontSize:12, cursor:'pointer', textDecoration:'underline', fontFamily:'inherit', padding:0 }}>
            → Go to Brain Diagnostic
          </button>
        </Card>
      )}
      <div>
        <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:10 }}>
          <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase' }}>Grading Assignments</div>
          <Btn onClick={() => setSRows(r => [...r, { name:'', n:'30', m:'10' }])} ghost sm>+ Add Assignment</Btn>
        </div>
        {sRows.map((r,i) => (
          <div key={i} style={{ display:'grid', gridTemplateColumns:'1fr 90px 90px auto', gap:8, marginBottom:8, alignItems:'end' }}>
            <div>
              {i===0 && <div style={{ fontSize:9, color:C.dim, fontWeight:700, letterSpacing:'0.06em', textTransform:'uppercase', marginBottom:4 }}>Assignment Name</div>}
              <input value={r.name} onChange={e => { const u=[...sRows]; u[i].name=e.target.value; setSRows(u); }}
                placeholder="e.g., Argumentative Essay"
                style={{ background:C.raised, color:C.text, border:`1px solid ${C.border}`, borderRadius:7, padding:'8px 10px', fontSize:13, width:'100%', fontFamily:'inherit' }} />
            </div>
            <div>
              {i===0 && <div style={{ fontSize:9, color:C.dim, fontWeight:700, letterSpacing:'0.06em', textTransform:'uppercase', marginBottom:4 }}># Papers</div>}
              <input type="number" value={r.n} onChange={e => { const u=[...sRows]; u[i].n=e.target.value; setSRows(u); }}
                style={{ background:C.raised, color:C.text, border:`1px solid ${C.border}`, borderRadius:7, padding:'8px 10px', fontSize:13, width:'100%', fontFamily:'inherit' }} />
            </div>
            <div>
              {i===0 && <div style={{ fontSize:9, color:C.dim, fontWeight:700, letterSpacing:'0.06em', textTransform:'uppercase', marginBottom:4 }}>Min/Paper</div>}
              <input type="number" value={r.m} onChange={e => { const u=[...sRows]; u[i].m=e.target.value; setSRows(u); }}
                style={{ background:C.raised, color:C.text, border:`1px solid ${C.border}`, borderRadius:7, padding:'8px 10px', fontSize:13, width:'100%', fontFamily:'inherit' }} />
            </div>
            {sRows.length > 1 && (
              <button onClick={() => setSRows(r => r.filter((_,j) => j!==i))}
                style={{ background:'#2d0000', border:`1px solid ${C.red}44`, borderRadius:7, color:C.red, cursor:'pointer', padding:'8px 10px', fontSize:12, fontFamily:'inherit' }}>
                ✕
              </button>
            )}
          </div>
        ))}
      </div>
      <Btn onClick={handleSchedule} disabled={loading} color={C.cyan}>
        {loading ? '⚙ Optimizing...' : '📅 Build My Grading Schedule'}
      </Btn>
      {loading && <Spinner msg="Optimizing your grading calendar..." />}
      {sOut && (
        <>
          <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase' }}>Your Optimized Schedule</div>
          <Output text={sOut} />
        </>
      )}
    </div>
  );

  const renderFeynman = () => (
    <div style={{ display:'flex', flexDirection:'column', gap:20 }}>
      <SH icon="🎓" title="Feynman Module" sub="Verify your understanding before grading — and teach your students to do the same" />
      <Card>
        <div style={{ fontSize:10, color:C.cyan, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:10 }}>The 4-Step Feynman Technique</div>
        {[
          '1 · Choose a concept you need to grade student work on',
          '2 · Explain it as simply as a child could understand',
          '3 · AI identifies every gap in your explanation',
          '4 · Simplify again until all gaps are closed — then grade',
        ].map((s,i) => (
          <div key={i} style={{ fontSize:12, color:C.muted, marginBottom:6, paddingLeft:2 }}>{s}</div>
        ))}
      </Card>
      <div style={{ display:'grid', gridTemplateColumns:'2fr 1fr', gap:12 }}>
        <div>
          <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:5 }}>Concept You're Grading ★</div>
          <input value={fCon} onChange={e => setFCon(e.target.value)}
            placeholder="e.g., Photosynthesis, Thesis statements, The Civil War, Quadratic equations"
            style={{ background:C.raised, color:C.text, border:`1px solid ${C.border}`, borderRadius:7, padding:'10px 12px', fontSize:13, width:'100%', fontFamily:'inherit' }} />
        </div>
        <Sel label="Grade Level" value={fGr} onChange={setFGr} opts={GRADES} />
      </div>
      <TA label="Explain This Concept Simply — as if to a 10-year-old ★" value={fExp} onChange={setFExp} rows={4}
        placeholder="Write your simple explanation here. Don't overthink it — the AI will find the gaps." />
      <Btn onClick={handleFeynman} disabled={loading || !fCon || !fExp} color={C.cyan}>
        {loading ? '⚙ Analyzing...' : '🎓 Check My Understanding'}
      </Btn>
      {loading && <Spinner msg="Running Feynman analysis..." />}
      {fOut && (
        <>
          <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase' }}>Feynman Analysis Report</div>
          <Output text={fOut} />
        </>
      )}
    </div>
  );

  const renderBARS = () => {
    if (!profile) return (
      <div style={{ display:'flex', flexDirection:'column', gap:20 }}>
        <SH icon="🚀" title="BARS Profile" sub="NASA-inspired behavioral accommodations for your brain type" />
        <Card style={{ textAlign:'center', padding:60 }}>
          <div style={{ fontSize:56, marginBottom:16 }}>🚀</div>
          <p style={{ color:C.muted, fontSize:14, marginBottom:20 }}>Complete the Brain Diagnostic to activate your personalized BARS accommodation system</p>
          <Btn onClick={() => setTab('diagnostic')}>Start Brain Diagnostic →</Btn>
        </Card>
      </div>
    );
    const pk = PEAK[profile.chronotype] ?? {};
    return (
      <div style={{ display:'flex', flexDirection:'column', gap:20 }}>
        <SH icon="🚀" title="Your BARS Profile" sub="Behaviorally Anchored Rating Scale — NASA-grade performance system for teachers" />
        <Card accent={C.cyan} glow>
          <div style={{ display:'flex', justifyContent:'space-between', alignItems:'flex-start', marginBottom:16 }}>
            <div>
              <div style={{ fontSize:20, fontWeight:800, color:C.cyan }}>{profile.brainType}</div>
              <div style={{ fontSize:12, color:C.muted, marginTop:2 }}>Chronotype: {profile.chronotype}</div>
              <div style={{ fontSize:11, color:C.muted, marginTop:2 }}>Subject: {profile.subject}</div>
            </div>
            <div style={{ textAlign:'right' }}>
              <div style={{ fontSize:30, fontWeight:800, color:C.green, lineHeight:1 }}>90%</div>
              <div style={{ fontSize:9, color:C.dim, textTransform:'uppercase', letterSpacing:'0.05em' }}>workload reduction</div>
            </div>
          </div>
          <div style={{ background:'#000', borderRadius:7, padding:12, marginBottom:14 }}>
            <div style={{ fontSize:9, color:C.dim, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:8 }}>Cognitive Performance Map</div>
            {[
              { dot:'🟢', k:'PEAK — schedule ALL complex grading here:', v:pk.peak      },
              { dot:'🟡', k:'SECONDARY — review AI output, easy tasks:', v:pk.secondary },
              { dot:'🔴', k:'DO NOT GRADE — cognitive performance low:', v:pk.avoid     },
            ].map((x,i) => (
              <div key={i} style={{ display:'flex', gap:10, marginBottom:8 }}>
                <span style={{ fontSize:13, flexShrink:0 }}>{x.dot}</span>
                <span style={{ fontSize:12, color:C.text, lineHeight:1.4 }}>
                  <strong style={{ color:C.muted }}>{x.k}</strong> <span style={{ color:C.cyan }}>{x.v}</span>
                </span>
              </div>
            ))}
          </div>
          <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr 1fr 1fr', gap:8 }}>
            {[
              { l:'Before AI',   v:`${profile.currentHours}h/wk`   },
              { l:'After AI',    v:`${profile.remainingHours}h/wk`  },
              { l:'Freed',       v:`${profile.savedHours}h/wk`      },
              { l:'Focus Window',v:`${profile.focusMins} min`        },
            ].map((x,i) => (
              <div key={i} style={{ background:'#000', borderRadius:6, padding:'8px 10px', textAlign:'center' }}>
                <div style={{ fontSize:16, fontWeight:800, color: i===2 ? C.green : C.cyan }}>{x.v}</div>
                <div style={{ fontSize:9, color:C.dim, textTransform:'uppercase', letterSpacing:'0.05em', marginTop:2 }}>{x.l}</div>
              </div>
            ))}
          </div>
        </Card>
        <div>
          <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:12 }}>Active Accommodations — {profile.brainType}</div>
          {(ACCOMMODATIONS[profile.brainType] ?? ACCOMMODATIONS.Neurotypical).map((a,i) => (
            <div key={i} style={{ display:'flex', gap:14, alignItems:'center', background:C.surface,
              border:`1px solid ${C.green}33`, borderRadius:8, padding:'11px 16px', marginBottom:8 }}>
              <span style={{ fontSize:20, flexShrink:0 }}>{a.icon}</span>
              <span style={{ fontSize:13, color:'#bbf7d0' }}>{a.t}</span>
            </div>
          ))}
        </div>
        <Card>
          <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:10 }}>Mental Health Support — All Protocols Active</div>
          <div style={{ display:'flex', flexWrap:'wrap', gap:8 }}>
            {['ADHD-Inattentive','ADHD-Hyperactive','ADHD-Combined','Anxiety','Depression','Burnout','OCD','PTSD/Trauma','Bipolar'].map(c => (
              <Pill key={c}>{c}</Pill>
            ))}
          </div>
        </Card>
      </div>
    );
  };

  const renderCert = () => (
    <div style={{ display:'flex', flexDirection:'column', gap:20 }}>
      <SH icon="🏆" title="GradeFreed Certification" sub="5 levels — Associate through Master Educator" />
      <Card accent={C.amber}>
        <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:10 }}>
          <span style={{ fontSize:11, color:C.muted }}>Current Level</span>
          <div style={{ display:'flex', alignItems:'center', gap:8 }}>
            <Tag color={C.amber}>Level {currentLv}</Tag>
            <span style={{ fontSize:13, fontWeight:700, color:C.amber }}>{CERT_LEVELS[currentLv-1]?.n}</span>
          </div>
        </div>
        <div style={{ background:C.raised, borderRadius:6, height:8, overflow:'hidden' }}>
          <div style={{ background:`linear-gradient(to right, ${C.amber}, ${C.red})`, width:`${(currentLv/5)*100}%`, height:'100%', borderRadius:6, transition:'width 0.5s ease' }} />
        </div>
        <div style={{ display:'flex', justifyContent:'space-between', marginTop:4 }}>
          <span style={{ fontSize:9, color:C.dim }}>Associate</span>
          <span style={{ fontSize:9, color:C.dim }}>Master Educator</span>
        </div>
      </Card>

      {CERT_LEVELS.map((c,i) => {
        const lv   = i + 1;
        const done = certDone(lv);
        const comp = done.filter(Boolean).length;
        const active = lv <= currentLv + 1;
        return (
          <div key={lv} style={{ background:C.surface, borderRadius:10, padding:18,
            border:`1px solid ${lv<currentLv ? C.green+'55' : lv===currentLv ? C.amber+'55' : C.border}`,
            opacity: active ? 1 : 0.4 }}>
            <div style={{ display:'flex', justifyContent:'space-between', alignItems:'center', marginBottom:10 }}>
              <div style={{ display:'flex', alignItems:'center', gap:10 }}>
                <span style={{ fontSize:18 }}>{lv<currentLv ? '✅' : lv===currentLv ? '🔓' : '🔒'}</span>
                <div>
                  <Tag color={lv<currentLv ? C.green : lv===currentLv ? C.amber : C.dim}>Level {lv}</Tag>
                  <span style={{ fontSize:13, fontWeight:700, color:C.text, marginLeft:8 }}>{c.n}</span>
                </div>
              </div>
              <span style={{ fontSize:11, color:C.muted }}>{comp} / {c.reqs.length}</span>
            </div>
            {c.reqs.map((req,j) => (
              <div key={j} style={{ display:'flex', alignItems:'center', gap:10, marginBottom:6 }}>
                <span style={{ fontSize:12, color: done[j] ? C.green : C.dim, flexShrink:0 }}>{done[j] ? '✅' : '○'}</span>
                <span style={{ fontSize:12, color: done[j] ? '#bbf7d0' : C.dim }}>{req}</span>
              </div>
            ))}
          </div>
        );
      })}

      <Card>
        <div style={{ fontSize:10, color:C.muted, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:12 }}>📊 Progress Tracker</div>
        <div style={{ display:'grid', gridTemplateColumns:'1fr 1fr 1fr', gap:10 }}>
          {[
            { l:'Papers Graded', v:graded,    t:100, color:C.cyan   },
            { l:'Rubrics Built', v:rCount,    t:10,  color:C.purple  },
            { l:'Min Saved',     v:timeSaved, t:600, color:C.green   },
          ].map((s,i) => (
            <div key={i} style={{ background:C.raised, borderRadius:8, padding:12 }}>
              <div style={{ fontSize:22, fontWeight:800, color:s.color }}>{s.v}</div>
              <div style={{ fontSize:10, color:C.dim, textTransform:'uppercase', letterSpacing:'0.05em', marginBottom:6 }}>{s.l}</div>
              <div style={{ background:C.surface, borderRadius:4, height:4, overflow:'hidden' }}>
                <div style={{ background:s.color, width:`${Math.min((s.v/s.t)*100,100)}%`, height:'100%', transition:'width 0.4s' }} />
              </div>
              <div style={{ fontSize:9, color:C.dim, marginTop:3 }}>Goal: {s.t}</div>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );

  // ── VIEW ROUTER ──
  const renderView = () => {
    switch(tab) {
      case 'diagnostic': return renderDiagnostic();
      case 'grader':     return renderGrader();
      case 'rubric':     return renderRubric();
      case 'scheduler':  return renderScheduler();
      case 'feynman':    return renderFeynman();
      case 'bars':       return renderBARS();
      case 'cert':       return renderCert();
      default:           return renderDashboard();
    }
  };

  // ── MAIN RENDER ──
  return (
    <div style={{ display:'flex', minHeight:'100vh', background:C.bg, color:C.text, fontFamily:'system-ui,-apple-system,BlinkMacSystemFont,sans-serif' }}>

      {/* Toast */}
      {toast && (
        <div style={{ position:'fixed', top:16, right:16, zIndex:9999,
          background: toast.ok ? '#001a0d' : '#1a0000',
          border:`1px solid ${toast.ok ? C.green : C.red}66`,
          borderRadius:9, padding:'12px 18px',
          color: toast.ok ? '#86efac' : '#fca5a5',
          fontSize:13, fontWeight:600, maxWidth:320, lineHeight:1.4,
          boxShadow:`0 8px 32px ${toast.ok ? C.green : C.red}22`,
          animation:'fadeIn 0.2s ease' }}>
          {toast.msg}
        </div>
      )}

      {/* Sidebar */}
      <div style={{ width:200, background:C.surface, borderRight:`1px solid ${C.border}`, display:'flex', flexDirection:'column', flexShrink:0 }}>
        <div style={{ padding:'20px 16px', borderBottom:`1px solid ${C.border}` }}>
          <div style={{ fontSize:14, fontWeight:800, color:C.cyan, letterSpacing:'-0.01em' }}>GradeFreed AI</div>
          <div style={{ fontSize:8, color:C.dim, fontWeight:700, letterSpacing:'0.1em', textTransform:'uppercase', marginTop:2 }}>Score Higher Education</div>
          {profile && (
            <div style={{ marginTop:10, display:'flex', gap:5, flexWrap:'wrap' }}>
              <Tag color={C.green}>{profile.brainType.split('-')[0]}</Tag>
              <Tag color={C.cyan}>{profile.chronotype}</Tag>
            </div>
          )}
        </div>

        <nav style={{ flex:1, padding:'10px 8px', overflowY:'auto' }}>
          {NAV.map(n => (
            <button key={n.id} onClick={() => setTab(n.id)} style={{
              display:'flex', alignItems:'center', gap:9, width:'100%',
              padding:'9px 10px', borderRadius:7, border:'none', cursor:'pointer',
              background: tab===n.id ? C.cyan+'15' : 'transparent',
              color: tab===n.id ? C.cyan : C.muted,
              fontSize:12, fontWeight: tab===n.id ? 600 : 400,
              marginBottom:2, textAlign:'left', fontFamily:'inherit', transition:'all 0.12s',
            }}>
              <span style={{ fontSize:14 }}>{n.icon}</span>
              <span style={{ flex:1 }}>{n.label}</span>
              {n.id==='grader' && graded>0 && (
                <span style={{ background:C.cyan+'33', color:C.cyan, borderRadius:10, padding:'1px 6px', fontSize:9, fontWeight:700 }}>{graded}</span>
              )}
              {n.id==='bars' && !profile && (
                <span style={{ width:6, height:6, borderRadius:'50%', background:C.amber, flexShrink:0 }} />
              )}
            </button>
          ))}
        </nav>

        <div style={{ padding:'12px 16px', borderTop:`1px solid ${C.border}` }}>
          <div style={{ fontSize:9, color:C.dim, fontWeight:700, letterSpacing:'0.07em', textTransform:'uppercase', marginBottom:7 }}>Session</div>
          {[
            { v:`${graded} graded`,       c:C.cyan   },
            { v:`${timeSaved} min saved`, c:C.green  },
            { v:`${rCount} rubrics`,       c:C.purple },
          ].map((s,i) => (
            <div key={i} style={{ fontSize:11, color:s.c, marginBottom:4, fontVariantNumeric:'tabular-nums' }}>{s.v}</div>
          ))}
        </div>
      </div>

      {/* Main Content */}
      <div style={{ flex:1, overflowY:'auto', padding:'28px 32px' }}>
        <div style={{ maxWidth:800, margin:'0 auto' }}>
          {renderView()}
        </div>
      </div>

      <style>{`
        *{box-sizing:border-box;margin:0;padding:0;}
        @keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
        @keyframes fadeIn{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:translateY(0)}}
        textarea,input,select{outline:none;}
        textarea:focus,input:focus,select:focus{border-color:${C.cyan}!important;box-shadow:0 0 0 2px ${C.cyan}1a!important;}
        button:hover:not(:disabled){filter:brightness(1.14);transform:translateY(-1px);}
        button:active:not(:disabled){transform:translateY(0);}
        ::-webkit-scrollbar{width:5px;height:5px;}
        ::-webkit-scrollbar-track{background:${C.surface};}
        ::-webkit-scrollbar-thumb{background:${C.border};border-radius:3px;}
      `}</style>
    </div>
  );
}
