  const notify = (msg, ok = true) => {
    setToast({ msg, ok });
    setTimeout(() => setToast(null), 4000);
  };

  // ── DIAGNOSTIC LOGIC ──
  const q   = QUIZ[step];
  const pct = Math.round((step / QUIZ.length) * 100);

  const pick = (val) => {
    const next = { ...ans, [q.id]: val };
    setAns(next);
    setTimeout(() => {
      if (step < QUIZ.length - 1) setStep(s => s + 1);
      else { const p = buildProfile(next); setProfile(p); notify(`🎉 Profile ready — ${p.brainType} · ${p.chronotype}`); }
    }, 320);
  };

  const textNext = () => {
    const next = { ...ans, [q.id]: txt };
    if (step < QUIZ.length - 1) { setStep(s => s + 1); setTxt(''); setAns(next); }
    else { const p = buildProfile(next); setProfile(p); notify('🎉 Brain Profile is now active!'); }
  };

  // ── AI HANDLERS ──
  // UPGRADED (Sprint 1 / Phase 2.1): no more giant inline prompt string.
  // The server (/api/grade) owns the prompt + JSON contract. The frontend
  // just sends structured fields and receives a structured object back —
  // score, rubricBreakdown, strengths, weaknesses, feedback, suggestedRevisions,
  // flagForReview. This matches the exact Phase 2 spec.
  const handleGrade = async () => {
    if (!gWork.trim()) { notify('Paste student work first.', false); return; }
    if (gWork.length > 15000) { notify('Student work is too long (max ~15,000 characters). Trim it and try again.', false); return; }
    setLoading(true); setGOut(''); setGResult(null);
    try {
      const std = STANDARDS[gStd];
      const result = await gradeSubmission({
        subject: gSub,
        gradeLevel: gGr,
        standard: gStd,
        standardCode: std?.code ?? '',
        assignmentPrompt: gPmt || 'General assignment',
        studentWork: gWork,
        maxScore: 4,
      });
      setGResult(result);
      setGraded(c => c + 1);
      notify('✅ Paper graded — ~8 minutes saved.');
    } catch (e) {
      setGOut(e.message);
      notify(`Grading failed: ${e.message}`, false);
    }
    setLoading(false);
  };

  // UPGRADED (Sprint 2 / Phase 2.2): dedicated /api/rubric route returns a
  // real object — categories with proficiency levels, accommodations,
  // common mistakes, and an exemplar description — matching the exact
  // Phase 2 spec (standards-aligned, scoring categories, proficiency
  // levels, accommodations).
  const handleRubric = async () => {
    if (!rObj.trim()) { notify('Enter an assignment objective first.', false); return; }
    setLoading(true); setROut(''); setRResult(null);
    try {
      const std = STANDARDS[rStd];
      const result = await buildRubric({
        objective: rObj,
        standard: rStd,
        standardCode: std?.code ?? '',
        gradeLevel: rGr,
        pointScale: Number(rSc),
      });
      setRResult(result);
      setRCount(c => c + 1);
      notify('📋 MCAP rubric built and ready.');
    } catch (e) {
      setROut(e.message);
      notify(`Rubric failed: ${e.message}`, false);
    }
    setLoading(false);
  };

  const handleSchedule = async () => {
    const validAssignments = sAssignments.filter(a => a.name.trim());
    if (validAssignments.length === 0) { notify('Add at least one assignment with a name.', false); return; }
    setLoading(true); setSOut(''); setSResult(null);
    try {
      const pk = PEAK[profile?.chronotype] ?? PEAK.Bear;
      const result = await buildSchedule({
        brainType: profile?.brainType ?? 'Not specified',
        chronotype: profile?.chronotype ?? 'Bear',
        peakWindow: pk.peak,
        focusMinutes: profile?.focusMins ?? '25',
        assignments: validAssignments.map(a => ({
          id: a.id, name: a.name, paperCount: Number(a.paperCount) || 0,
          minutesPerPaper: Number(a.minutesPerPaper) || 0, dueDate: a.dueDate,
        })),
        interventions: sInterventions.filter(iv => iv.studentLabel.trim()),
      });
      setSResult(result);
      addSnapshot(graded, rCount); // lightweight progress tracking checkpoint
      notify('📅 Schedule optimized for your brain type.');
    } catch (e) {
      setSOut(e.message);
      notify(`Scheduler failed: ${e.message}`, false);
