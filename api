  // localStorage. This is intentionally minimal — we save progress counters
  // and the brain profile, NOT full grading history (that belongs in a real
  // database, see Phase 3 checklist item). Small footprint, survives refresh.
  useEffect(() => {
    // Merge, don't overwrite — addSnapshot() writes to the same key from
    // the Scheduler, and a blind overwrite here would silently erase
    // snapshot history every time profile/graded/rCount changes.
    const existing = loadSaved() ?? {};
    saveState({ ...existing, profile, graded, rCount });
