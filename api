// PERSISTENCE (Sprint 1, Finding #2 fix):
// Zero-cost localStorage bridge — survives page refresh, browser close,
// and tab crashes. This is not a real database (it's per-browser, not
// per-account), but it eliminates the #1 beta-killer bug: "I lost
// everything when I refreshed the page." Wrapped in try/catch because
// localStorage can throw in private-browsing mode on some browsers.
const STORAGE_KEY = 'gradefreed_v1';

const loadSaved = () => {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : null;
  } catch { return null; }
};

const saveState = (data) => {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch { /* private mode — silently skip */ }
};

// LIGHTWEIGHT PROGRESS TRACKING (Phase 2.3 requirement, minimal version):
// Not the full Analytics screen (that's a later phase) — just a simple
// "since your last schedule build" delta, computed from real saved
// numbers, capped at 10 snapshots so localStorage never grows unbounded.
const addSnapshot = (graded, rCount) => {
  const saved = loadSaved() ?? {};
  const snapshots = Array.isArray(saved.snapshots) ? saved.snapshots : [];
  const today = new Date().toISOString().slice(0, 10);
  const withoutToday = snapshots.filter(s => s.date !== today);
  const updated = [...withoutToday, { date: today, graded, rCount }].slice(-10);
  saveState({ ...saved, snapshots: updated });
  return updated;
};

